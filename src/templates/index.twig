{% set elementType = "hybridinteractive\\SimpleContactForm\\Elements\\Submission" %}
{% set selectedSubnavItem = 'submissions' %}
{% extends '_layouts/elementindex' %}

{% set title = "Submissions" |t %}

{% if crumbs is not defined %}
    {% set crumbs = [
        { label: craft.simpleContactForm.name, url: url('simple-contact-form') }
    ] %}
{% endif %}

{% set defaultLimit = 50 %}
{% set limitOptions = [25, 50, 100] %}
{% set limitStorageKey = 'simple-contact-form-submissions-limit' %}

{% block footer %}
    <div class="flex flex-nowrap" style="align-items: center; gap: 1rem;">
        <div class="flex flex-nowrap" style="align-items: center; gap: 0.5rem;">
            <label for="submissions-limit-select" class="light">{{ 'Per page'|t('simple-contact-form') }}:</label>
            <select id="submissions-limit-select" class="select" style="width: auto;">
                {% for option in limitOptions %}
                    <option value="{{ option }}">{{ option }}</option>
                {% endfor %}
            </select>
        </div>
        {{ parent() }}
    </div>
{% endblock %}

{% block initJs %}
    (function() {
        const storageKey = '{{ limitStorageKey }}';
        const defaultLimit = {{ defaultLimit }};
        const savedLimit = parseInt(localStorage.getItem(storageKey) || defaultLimit, 10);
        Craft.defaultIndexCriteria = Object.assign({}, Craft.defaultIndexCriteria || {}, { limit: savedLimit });
    })();
    {{ parent() }}
{% endblock %}

{% js %}
    (function() {
        const limitSelect = document.getElementById('submissions-limit-select');
        const storageKey = '{{ limitStorageKey }}';
        const defaultLimit = {{ defaultLimit }};

        if (limitSelect) {
            const savedLimit = parseInt(localStorage.getItem(storageKey) || defaultLimit, 10);
            limitSelect.value = [25, 50, 100].includes(savedLimit) ? savedLimit : defaultLimit;

            limitSelect.addEventListener('change', function() {
                const newLimit = parseInt(this.value, 10);
                localStorage.setItem(storageKey, newLimit);
                if (typeof Craft !== 'undefined' && Craft.elementIndex) {
                    Craft.elementIndex.settings.criteria = Craft.elementIndex.settings.criteria || {};
                    Craft.elementIndex.settings.criteria.limit = newLimit;
                    Craft.elementIndex.updateElements(true, true);
                }
            });
        }
    })();
{% endjs %}
